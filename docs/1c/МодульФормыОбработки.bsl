// ============================================================================
// DC Bakery: загрузка клиентов и заказов сайта в 1С (Бухгалтерия 8.3)
// Модуль формы внешней обработки. Как собрать — см. ИНСТРУКЦИЯ.md рядом.
//
// Обработка исходящими HTTPS-запросами забирает данные с сайта и создаёт:
//  - "Загрузить клиентов": контрагентов по зарегистрированным аккаунтам сайта.
//    Связка аккаунт ↔ контрагент — метка "Сайт DC Bakery, клиент <id>"
//    в комментарии контрагента. С БИН → подгруппа "Официалы (безнал)",
//    без БИН → подгруппа "Частники" (внутри группы "B2B сайт").
//  - "Загрузить заказы": документы "Счет на оплату покупателю" (непроведённые,
//    на проверку бухгалтеру). Контрагент ищется сначала по метке клиента,
//    затем по БИН, затем по наименованию.
// Повторный запуск дубликатов не создаёт (метки клиентов и номера заказов).
// ============================================================================

// ─── НАСТРОЙКИ: заполните три значения ниже перед сохранением ───

&НаСервереБезКонтекста
Функция ПолучитьНастройки()
	Настройки = Новый Структура;
	Настройки.Вставить("Сервер",             "ВАШ-ДОМЕН-САЙТА");    // например dc-bakery.kz (без https://)
	Настройки.Вставить("Токен",              "ВСТАВЬТЕ-ТОКЕН");     // значение ONEC_EXPORT_TOKEN с сайта
	Настройки.Вставить("ИмяОрганизации",     "");                   // пусто = первая организация в базе
	Настройки.Вставить("Путь",               "/api/integrations/1c/orders");
	Настройки.Вставить("ПутьКлиенты",        "/api/integrations/1c/clients");
	Настройки.Вставить("ДнейНазад",          14);
	Настройки.Вставить("ГруппаКонтрагентов", "B2B сайт");
	Настройки.Вставить("ГруппаНоменклатуры", "B2B сайт");
	Возврат Настройки;
КонецФункции

// ─── Команды формы ───

&НаКлиенте
Процедура ПроверитьСвязь(Команда)
	Результат = ПроверитьСвязьНаСервере();
	ПоказатьПредупреждение(, Результат, 60);
КонецПроцедуры

&НаКлиенте
Процедура ЗагрузитьЗаказы(Команда)
	Результат = ЗагрузитьЗаказыНаСервере();
	ПоказатьПредупреждение(, Результат, 120);
КонецПроцедуры

&НаКлиенте
Процедура ЗагрузитьКлиентов(Команда)
	Результат = ЗагрузитьКлиентовНаСервере();
	ПоказатьПредупреждение(, Результат, 120);
КонецПроцедуры

// ─── Серверная часть ───

&НаСервереБезКонтекста
Функция ПолучитьОтветСайта(ОтносительныйПуть)
	Настройки = ПолучитьНастройки();

	ССЛ = Новый ЗащищенноеСоединениеOpenSSL(Неопределено, Неопределено);
	Соединение = Новый HTTPСоединение(Настройки.Сервер, 443, , , , 30, ССЛ);

	Запрос = Новый HTTPЗапрос(ОтносительныйПуть);
	Запрос.Заголовки.Вставить("Authorization", "Bearer " + Настройки.Токен);
	Запрос.Заголовки.Вставить("Accept", "application/json");

	Ответ = Соединение.Получить(Запрос);
	Тело = Ответ.ПолучитьТелоКакСтроку("UTF-8");

	Если Ответ.КодСостояния <> 200 Тогда
		ВызватьИсключение "Сайт ответил кодом " + Ответ.КодСостояния + ": " + Лев(Тело, 300);
	КонецЕсли;

	Чтение = Новый ЧтениеJSON;
	Чтение.УстановитьСтроку(Тело);
	Данные = ПрочитатьJSON(Чтение, Истина); // Истина = читать объекты как Соответствие
	Чтение.Закрыть();

	Возврат Данные;
КонецФункции

&НаСервереБезКонтекста
Функция ПроверитьСвязьНаСервере()
	Настройки = ПолучитьНастройки();
	Попытка
		Данные = ПолучитьОтветСайта(Настройки.Путь + "?confirmed=1");
		Возврат "Связь есть. Заказов за период: " + Строка(Данные.Получить("count"));
	Исключение
		Возврат "ОШИБКА СВЯЗИ: " + ОписаниеОшибки();
	КонецПопытки;
КонецФункции

// Ищет в метаданных первый существующий реквизит из списка кандидатов
&НаСервереБезКонтекста
Функция НайтиИмяРеквизита(МетаОбъект, Кандидаты)
	Для Каждого Имя Из Кандидаты Цикл
		Если МетаОбъект.Реквизиты.Найти(Имя) <> Неопределено Тогда
			Возврат Имя;
		КонецЕсли;
	КонецЦикла;
	Возврат "";
КонецФункции

&НаСервереБезКонтекста
Функция НайтиИлиСоздатьГруппу(Менеджер, Наименование, Родитель = Неопределено)
	Группа = Менеджер.НайтиПоНаименованию(Наименование, Истина, Родитель);
	Если Группа = Неопределено ИЛИ Группа.Пустая() Тогда
		Объект = Менеджер.СоздатьГруппу();
		Объект.Наименование = Наименование;
		Если Родитель <> Неопределено Тогда
			Объект.Родитель = Родитель;
		КонецЕсли;
		Объект.Записать();
		Возврат Объект.Ссылка;
	КонецЕсли;
	Возврат Группа;
КонецФункции

// ─── Связка «аккаунт сайта ↔ контрагент» через метку в комментарии ───

&НаСервереБезКонтекста
Функция МеткаКлиента(ИдКлиента)
	Возврат "Сайт DC Bakery, клиент " + ИдКлиента;
КонецФункции

&НаСервереБезКонтекста
Функция НайтиКонтрагентаПоМетке(ИдКлиента, ИмяРеквизитаКомментария)
	Если ПустаяСтрока(ИдКлиента) ИЛИ ПустаяСтрока(ИмяРеквизитаКомментария) Тогда
		Возврат Неопределено;
	КонецЕсли;
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1 Ссылка ИЗ Справочник.Контрагенты КАК К
	|ГДЕ К." + ИмяРеквизитаКомментария + " ПОДОБНО &Метка";
	Запрос.УстановитьПараметр("Метка", "%клиент " + ИдКлиента + "%");
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Ссылка;
	КонецЕсли;
	Возврат Неопределено;
КонецФункции

&НаСервереБезКонтекста
Функция НайтиКонтрагентаПоБИН(БИН, ИмяРеквизитаБИН)
	Если ПустаяСтрока(БИН) ИЛИ ПустаяСтрока(ИмяРеквизитаБИН) Тогда
		Возврат Неопределено;
	КонецЕсли;
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1 Ссылка ИЗ Справочник.Контрагенты КАК К
	|ГДЕ К." + ИмяРеквизитаБИН + " = &БИН";
	Запрос.УстановитьПараметр("БИН", БИН);
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Ссылка;
	КонецЕсли;
	Возврат Неопределено;
КонецФункции

&НаСервереБезКонтекста
Процедура ДописатьМетку(Объект, ИдКлиента, ИмяРеквизитаКомментария)
	Если ПустаяСтрока(ИмяРеквизитаКомментария) ИЛИ ПустаяСтрока(ИдКлиента) Тогда
		Возврат;
	КонецЕсли;
	Текущий = Строка(Объект[ИмяРеквизитаКомментария]);
	Если СтрНайти(Текущий, "клиент " + ИдКлиента) > 0 Тогда
		Возврат;
	КонецЕсли;
	Объект[ИмяРеквизитаКомментария] =
		?(ПустаяСтрока(Текущий), "", Текущий + Символы.ПС) + МеткаКлиента(ИдКлиента);
КонецПроцедуры

&НаСервереБезКонтекста
Процедура УстановитьЮрФизЛицо(Объект, ЭтоЮрЛицо)
	// Имена реквизита и перечисления различаются между релизами — ошибка не критична
	Попытка
		Если Метаданные.Справочники.Контрагенты.Реквизиты.Найти("ЮридическоеФизическоеЛицо") <> Неопределено Тогда
			Если ЭтоЮрЛицо Тогда
				Объект.ЮридическоеФизическоеЛицо = Перечисления.ЮридическоеФизическоеЛицо.ЮридическоеЛицо;
			Иначе
				Объект.ЮридическоеФизическоеЛицо = Перечисления.ЮридическоеФизическоеЛицо.ФизическоеЛицо;
			КонецЕсли;
		КонецЕсли;
	Исключение
	КонецПопытки;
КонецПроцедуры

&НаСервереБезКонтекста
Функция НайтиОрганизацию(ИмяОрганизации)
	Запрос = Новый Запрос;
	Если ПустаяСтрока(ИмяОрганизации) Тогда
		Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1 Ссылка ИЗ Справочник.Организации КАК Орг
		|ГДЕ НЕ Орг.ПометкаУдаления УПОРЯДОЧИТЬ ПО Орг.Код";
	Иначе
		Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1 Ссылка ИЗ Справочник.Организации КАК Орг
		|ГДЕ Орг.Наименование ПОДОБНО &Имя";
		Запрос.УстановитьПараметр("Имя", "%" + ИмяОрганизации + "%");
	КонецЕсли;
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Ссылка;
	КонецЕсли;
	ВызватьИсключение "Не найдена организация. Укажите ИмяОрганизации в настройках обработки.";
КонецФункции

&НаСервереБезКонтекста
Функция СчетУжеСоздан(НомерЗаказа)
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1 Док.Ссылка ИЗ Документ.СчетНаОплатуПокупателю КАК Док
	|ГДЕ Док.Комментарий ПОДОБНО &Метка";
	Запрос.УстановитьПараметр("Метка", "%" + НомерЗаказа + "%");
	Возврат НЕ Запрос.Выполнить().Пустой();
КонецФункции

&НаСервереБезКонтекста
Функция НайтиИлиСоздатьКонтрагента(Заказ, ИмяРеквизитаБИН, ИмяКомментария, Группа)
	ИдКлиента = Строка(Заказ.Получить("clientId"));
	БИН = Строка(Заказ.Получить("bin"));
	Наименование = Строка(Заказ.Получить("company"));

	// 1. По метке клиента сайта (создана кнопкой "Загрузить клиентов")
	Найденный = НайтиКонтрагентаПоМетке(ИдКлиента, ИмяКомментария);
	Если Найденный <> Неопределено Тогда
		Возврат Найденный;
	КонецЕсли;

	// 2. По БИН
	Найденный = НайтиКонтрагентаПоБИН(БИН, ИмяРеквизитаБИН);
	Если Найденный <> Неопределено Тогда
		Возврат Найденный;
	КонецЕсли;

	// 3. По наименованию
	Найденный = Справочники.Контрагенты.НайтиПоНаименованию(Наименование, Истина);
	Если Найденный <> Неопределено И НЕ Найденный.Пустая() Тогда
		Возврат Найденный;
	КонецЕсли;

	// 4. Создаём
	Новый_ = Справочники.Контрагенты.СоздатьЭлемент();
	Новый_.Наименование = Наименование;
	Новый_.Родитель = Группа;
	Если НЕ ПустаяСтрока(ИмяРеквизитаБИН) И НЕ ПустаяСтрока(БИН) Тогда
		Новый_[ИмяРеквизитаБИН] = БИН;
	КонецЕсли;
	МетаКонтрагенты = Метаданные.Справочники.Контрагенты;
	Если МетаКонтрагенты.Реквизиты.Найти("НаименованиеПолное") <> Неопределено Тогда
		Новый_.НаименованиеПолное = Наименование;
	КонецЕсли;
	УстановитьЮрФизЛицо(Новый_, НЕ ПустаяСтрока(БИН));
	ДописатьМетку(Новый_, ИдКлиента, ИмяКомментария);
	Новый_.Записать();
	Возврат Новый_.Ссылка;
КонецФункции

// ─── Загрузка клиентов: аккаунт сайта → контрагент ───

&НаСервереБезКонтекста
Функция ЗагрузитьКлиентовНаСервере()
	Настройки = ПолучитьНастройки();
	Создано = 0;
	Связано = 0;
	Пропущено = 0;
	Ошибки = 0;
	Журнал = "";

	Попытка
		Данные = ПолучитьОтветСайта(Настройки.ПутьКлиенты);
	Исключение
		Возврат "ОШИБКА СВЯЗИ: " + ОписаниеОшибки();
	КонецПопытки;

	Клиенты = Данные.Получить("clients");
	Если Клиенты = Неопределено Тогда
		Возврат "Сайт не вернул клиентов.";
	КонецЕсли;

	ИмяРеквизитаБИН = НайтиИмяРеквизита(Метаданные.Справочники.Контрагенты,
		СтрРазделить("БИН,ИИН,БИН_ИИН,БИНИИН,ИНН,РНН", ","));
	ИмяКомментария = НайтиИмяРеквизита(Метаданные.Справочники.Контрагенты,
		СтрРазделить("Комментарий,ДополнительнаяИнформация", ","));
	ГруппаОсновная = НайтиИлиСоздатьГруппу(Справочники.Контрагенты, Настройки.ГруппаКонтрагентов);
	ГруппаОфициалы = НайтиИлиСоздатьГруппу(Справочники.Контрагенты, "Официалы (безнал)", ГруппаОсновная);
	ГруппаЧастники = НайтиИлиСоздатьГруппу(Справочники.Контрагенты, "Частники", ГруппаОсновная);

	Для Каждого Клиент Из Клиенты Цикл
		ИдКлиента = Строка(Клиент.Получить("id"));
		Попытка
			// Уже связан с контрагентом — пропускаем
			Если НайтиКонтрагентаПоМетке(ИдКлиента, ИмяКомментария) <> Неопределено Тогда
				Пропущено = Пропущено + 1;
				Продолжить;
			КонецЕсли;

			БИН = Строка(Клиент.Получить("bin"));
			Наименование = Строка(Клиент.Получить("name"));
			ЭтоОфициал = (Строка(Клиент.Получить("type")) = "official");

			// Контрагент уже есть в базе (по БИН или имени) — дописываем метку
			Найденный = НайтиКонтрагентаПоБИН(БИН, ИмяРеквизитаБИН);
			Если Найденный = Неопределено Тогда
				ПоИмени = Справочники.Контрагенты.НайтиПоНаименованию(Наименование, Истина);
				Если ПоИмени <> Неопределено И НЕ ПоИмени.Пустая() Тогда
					Найденный = ПоИмени;
				КонецЕсли;
			КонецЕсли;

			Если Найденный <> Неопределено Тогда
				Если НЕ ПустаяСтрока(ИмяКомментария) Тогда
					Объект = Найденный.ПолучитьОбъект();
					ДописатьМетку(Объект, ИдКлиента, ИмяКомментария);
					Объект.Записать();
				КонецЕсли;
				Связано = Связано + 1;
				Продолжить;
			КонецЕсли;

			// Создаём нового контрагента
			Новый_ = Справочники.Контрагенты.СоздатьЭлемент();
			Новый_.Наименование = Наименование;
			Новый_.Родитель = ?(ЭтоОфициал, ГруппаОфициалы, ГруппаЧастники);
			Если НЕ ПустаяСтрока(ИмяРеквизитаБИН) И НЕ ПустаяСтрока(БИН) Тогда
				Новый_[ИмяРеквизитаБИН] = БИН;
			КонецЕсли;
			Если Метаданные.Справочники.Контрагенты.Реквизиты.Найти("НаименованиеПолное") <> Неопределено Тогда
				Новый_.НаименованиеПолное = Наименование;
			КонецЕсли;
			УстановитьЮрФизЛицо(Новый_, ЭтоОфициал);
			ДописатьМетку(Новый_, ИдКлиента, ИмяКомментария);
			// Контакты — строкой в комментарий, чтобы не зависеть от механизма
			// контактной информации конкретного релиза
			Телефон = Строка(Клиент.Получить("phone"));
			Почта = Строка(Клиент.Получить("email"));
			Если НЕ ПустаяСтрока(ИмяКомментария) И (НЕ ПустаяСтрока(Телефон) ИЛИ НЕ ПустаяСтрока(Почта)) Тогда
				Новый_[ИмяКомментария] = Строка(Новый_[ИмяКомментария]) + Символы.ПС
					+ СокрЛП("тел: " + Телефон + "  email: " + Почта);
			КонецЕсли;
			Новый_.Записать();
			Создано = Создано + 1;
		Исключение
			Ошибки = Ошибки + 1;
			Журнал = Журнал + Символы.ПС + Наименование + ": " + ОписаниеОшибки();
		КонецПопытки;
	КонецЦикла;

	Итог = "Готово. Создано контрагентов: " + Создано
		+ ", связано с существующими: " + Связано
		+ ", уже были связаны: " + Пропущено
		+ ", ошибок: " + Ошибки + ".";
	Если ПустаяСтрока(ИмяКомментария) Тогда
		Итог = Итог + Символы.ПС + "ВНИМАНИЕ: у справочника Контрагенты нет реквизита Комментарий — "
			+ "связка по метке недоступна, поиск будет по БИН и наименованию.";
	КонецЕсли;
	Если Ошибки > 0 Тогда
		Итог = Итог + Символы.ПС + "Подробности:" + Журнал;
	КонецЕсли;
	Возврат Итог;
КонецФункции

&НаСервереБезКонтекста
Функция НайтиИлиСоздатьНоменклатуру(Имя, Группа)
	Найденная = Справочники.Номенклатура.НайтиПоНаименованию(Имя, Истина);
	Если Найденная <> Неопределено И НЕ Найденная.Пустая() Тогда
		Возврат Найденная;
	КонецЕсли;

	Новая = Справочники.Номенклатура.СоздатьЭлемент();
	Новая.Наименование = Имя;
	Новая.Родитель = Группа;
	Если Метаданные.Справочники.Номенклатура.Реквизиты.Найти("НаименованиеПолное") <> Неопределено Тогда
		Новая.НаименованиеПолное = Имя;
	КонецЕсли;
	Новая.Записать();
	Возврат Новая.Ссылка;
КонецФункции

&НаСервереБезКонтекста
Функция ЗагрузитьЗаказыНаСервере()
	Настройки = ПолучитьНастройки();
	Создано = 0;
	Пропущено = 0;
	Ошибки = 0;
	Журнал = "";

	Попытка
		Данные = ПолучитьОтветСайта(Настройки.Путь + "?confirmed=1");
	Исключение
		Возврат "ОШИБКА СВЯЗИ: " + ОписаниеОшибки();
	КонецПопытки;

	Заказы = Данные.Получить("orders");
	Если Заказы = Неопределено Тогда
		Возврат "Сайт не вернул заказов.";
	КонецЕсли;

	ИмяРеквизитаБИН = НайтиИмяРеквизита(Метаданные.Справочники.Контрагенты,
		СтрРазделить("БИН,ИИН,БИН_ИИН,БИНИИН,ИНН,РНН", ","));
	ИмяКомментария = НайтиИмяРеквизита(Метаданные.Справочники.Контрагенты,
		СтрРазделить("Комментарий,ДополнительнаяИнформация", ","));
	ГруппаКонтрагентов = НайтиИлиСоздатьГруппу(Справочники.Контрагенты, Настройки.ГруппаКонтрагентов);
	ГруппаНоменклатуры = НайтиИлиСоздатьГруппу(Справочники.Номенклатура, Настройки.ГруппаНоменклатуры);
	Организация = НайтиОрганизацию(Настройки.ИмяОрганизации);

	МетаДок = Метаданные.Документы.СчетНаОплатуПокупателю;
	// Табличная часть с номенклатурой и количеством (обычно "Товары")
	ИмяТЧ = "";
	Для Каждого ТЧ Из МетаДок.ТабличныеЧасти Цикл
		Если ТЧ.Реквизиты.Найти("Номенклатура") <> Неопределено
			И ТЧ.Реквизиты.Найти("Количество") <> Неопределено Тогда
			ИмяТЧ = ТЧ.Имя;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	Если ПустаяСтрока(ИмяТЧ) Тогда
		Возврат "Не нашёл табличную часть с Номенклатурой в документе СчетНаОплатуПокупателю.";
	КонецЕсли;

	Для Каждого Заказ Из Заказы Цикл
		НомерЗаказа = Строка(Заказ.Получить("number"));
		Попытка
			Если СчетУжеСоздан(НомерЗаказа) Тогда
				Пропущено = Пропущено + 1;
				Продолжить;
			КонецЕсли;

			Контрагент = НайтиИлиСоздатьКонтрагента(Заказ, ИмяРеквизитаБИН, ИмяКомментария, ГруппаКонтрагентов);

			Док = Документы.СчетНаОплатуПокупателю.СоздатьДокумент();
			Док.Дата = ТекущаяДатаСеанса();
			Док.Организация = Организация;
			Док.Контрагент = Контрагент;
			Док.Комментарий = "Сайт DC Bakery, заказ " + НомерЗаказа;

			// Договор — только если реквизит есть и найдётся существующий
			Если МетаДок.Реквизиты.Найти("Договор") <> Неопределено Тогда
				Попытка
					ЗапросДог = Новый Запрос;
					ЗапросДог.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1 Ссылка ИЗ Справочник.ДоговорыКонтрагентов КАК Д
					|ГДЕ Д.Владелец = &Контрагент";
					ЗапросДог.УстановитьПараметр("Контрагент", Контрагент);
					ВыборкаДог = ЗапросДог.Выполнить().Выбрать();
					Если ВыборкаДог.Следующий() Тогда
						Док.Договор = ВыборкаДог.Ссылка;
					КонецЕсли;
				Исключение
				КонецПопытки;
			КонецЕсли;

			ТЧДок = Док[ИмяТЧ];
			МетаТЧ = МетаДок.ТабличныеЧасти.Найти(ИмяТЧ);
			Позиции = Заказ.Получить("items");
			Для Каждого Позиция Из Позиции Цикл
				Строка_ = ТЧДок.Добавить();
				Строка_.Номенклатура = НайтиИлиСоздатьНоменклатуру(
					Строка(Позиция.Получить("name")), ГруппаНоменклатуры);
				Строка_.Количество = Позиция.Получить("qty");
				Если МетаТЧ.Реквизиты.Найти("Цена") <> Неопределено Тогда
					Строка_.Цена = Позиция.Получить("price");
				КонецЕсли;
				Если МетаТЧ.Реквизиты.Найти("Сумма") <> Неопределено Тогда
					Строка_.Сумма = Позиция.Получить("sum");
				КонецЕсли;
			КонецЦикла;

			Док.Записать(РежимЗаписиДокумента.Запись); // непроведённым — на проверку бухгалтеру
			Создано = Создано + 1;
		Исключение
			Ошибки = Ошибки + 1;
			Журнал = Журнал + Символы.ПС + НомерЗаказа + ": " + ОписаниеОшибки();
		КонецПопытки;
	КонецЦикла;

	Итог = "Готово. Создано счетов: " + Создано
		+ ", уже были (пропущено): " + Пропущено
		+ ", ошибок: " + Ошибки + ".";
	Если Ошибки > 0 Тогда
		Итог = Итог + Символы.ПС + "Подробности:" + Журнал;
	КонецЕсли;
	Возврат Итог;
КонецФункции
